DB_HOST=localhost
DB_NAME=kareh_spa
DB_USER=root
DB_PASSWORD=
APP_KEY=change_this_to_a_long_random_secret
# Production domains (http://localhost:* Vite/dev origins are always merged in code — no need to duplicate).
APP_ALLOWED_ORIGINS=https://karehspa.co.ke,https://www.karehspa.co.ke
APP_ALLOW_LEGACY_TOKENS=false
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_ENCRYPTION=ssl
MAIL_TIMEOUT=15
MAIL_FROM_ADDRESS=your-gmail@gmail.com
MAIL_FROM_NAME=Kareh's Spa
STAFF_LOGIN_URL=https://karehspa.co.ke/admin/login
MEMBER_LOGIN_URL=https://karehspa.co.ke/login
FRONTEND_BASE_URL=https://karehspa.co.ke

# Pesapal Payment Gateway (API 3.0)
# Get live (production) keys at https://www.pesapal.com/dashboard/account/register
# Get sandbox (test) keys at https://developer.pesapal.com/sign-up
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=live
PESAPAL_IPN_URL=https://karehspa.co.ke/php_backend/api/pesapal.php?action=ipn
